# Build images from the repository root but keep context minimal.
**
!assistant/
!assistant/**
!control-plane/
!control-plane/**
!credential-executor/
!credential-executor/**
!gateway/
!gateway/**
!meta/
!meta/feature-flags/
!meta/feature-flags/feature-flag-registry.json
!packages/
!packages/**
!runtime/
!runtime/**
!skills/
!skills/**

# Exclude local dependencies and build outputs from included directories.
assistant/node_modules/
assistant/dist/
assistant/out/
assistant/build/
assistant/.env
assistant/.env.*
# Public control-plane service for Railway/Vercel auth and API proxying.
control-plane/node_modules/
control-plane/dist/
control-plane/out/
control-plane/build/
control-plane/.env
control-plane/.env.*
# Authoring-reference example plugins are not shipped with the production image.
assistant/examples/
credential-executor/node_modules/
credential-executor/.env
credential-executor/.env.*
gateway/node_modules/
gateway/.env
gateway/.env.*
packages/*/node_modules/
packages/*/.env
packages/*/.env.*
skills/**/node_modules/
skills/**/__tests__/
skills/**/*.test.ts
skills/**/dist/
skills/**/build/
