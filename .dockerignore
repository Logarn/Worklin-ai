# Exclude local dependencies and build outputs from included directories.
assistant/node_modules/
assistant/dist/
assistant/out/
assistant/build/
assistant/.env
assistant/.env.*
# Public control-plane service for Railway/Vercel auth and API proxying.
control-plane/node_modules/
control-plane/dist/
control-plane/out/
control-plane/build/
control-plane/.env
control-plane/.env.*
# Authoring-reference example plugins are not shipped with the production image.
assistant/examples/
credential-executor/node_modules/
credential-executor/.env
credential-executor/.env.*
gateway/node_modules/
gateway/.env
gateway/.env.*
packages/*/node_modules/
packages/*/.env
packages/*/.env.*
