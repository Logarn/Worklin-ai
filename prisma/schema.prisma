generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id               String            @id @default(cuid())
  externalId       String?           @unique
  email            String            @unique
  phone            String?
  firstName        String?
  lastName         String?
  createdAt        DateTime          @default(now())
  totalOrders      Int               @default(0)
  totalSpent       Float             @default(0)
  avgOrderValue    Float             @default(0)
  lastOrderDate    DateTime?
  firstOrderDate   DateTime?
  recencyScore     Int?
  frequencyScore   Int?
  monetaryScore    Int?
  segment          String?
  churnRiskScore   Int?
  orders           Order[]
  events           CustomerEvent[]
  campaignReceipts CampaignReceipt[]
}

model Order {
  id          String    @id @default(cuid())
  externalId  String?   @unique
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  orderNumber String
  totalAmount Float
  status      String
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?
  items       OrderItem[]

  @@index([customerId, createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float

  @@index([orderId])
  @@index([productId])
}

model Product {
  id                   String      @id @default(cuid())
  /// Shopify product id (REST resource id) as string — canonical sync key
  externalId           String?     @unique
  name                 String
  /// Display/inventory SKU; not unique (Shopify allows duplicates / blanks)
  sku                  String?
  price                Float
  category             String?
  imageUrl             String?
  avgReplenishmentDays Int?
  orderItems           OrderItem[]

  @@index([sku])
}

model CustomerEvent {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  eventType  String
  properties Json?
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt])
  @@index([eventType, createdAt])
}

model CustomerFeatureStore {
  id                 String   @id @default(cuid())
  identityId         String
  worklinCustomerId  String?
  shopifyCustomerId  String?
  klaviyoProfileId   String?
  identityConfidence String
  featureVersion     String
  timeframeDays      Int
  computedAt         DateTime
  status             String
  sourceSystems      Json
  sourceCoverage     Json
  commerceFeatures   Json
  engagementFeatures Json
  intentFeatures     Json
  lifecycleFeatures  Json
  cohortFeatures     Json
  derivedLabels      Json
  missingCapabilities Json
  caveats            Json
  metadata           Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([identityId, timeframeDays, featureVersion])
  @@index([identityId])
  @@index([worklinCustomerId])
  @@index([shopifyCustomerId])
  @@index([klaviyoProfileId])
  @@index([computedAt])
  @@index([status])
}

model CustomerScoreStore {
  id                   String   @id @default(cuid())
  identityId           String
  worklinCustomerId    String?
  shopifyCustomerId    String?
  klaviyoProfileId     String?
  sourceFeatureStoreId String?
  featureVersion       String
  scoringVersion       String
  timeframeDays        Int
  computedAt           DateTime
  status               String
  identityConfidence   String
  featureStatus        String
  scores               Json
  scoreSummary         Json
  actionPriorityHints  Json
  arbitrationMetadata  Json
  sourceFeatureSummary Json
  sourceCoverage       Json
  missingCapabilities  Json
  caveats              Json
  metadata             Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([identityId, timeframeDays, scoringVersion])
  @@index([identityId])
  @@index([worklinCustomerId])
  @@index([shopifyCustomerId])
  @@index([klaviyoProfileId])
  @@index([sourceFeatureStoreId])
  @@index([computedAt])
  @@index([status])
}

model Campaign {
  id          String            @id @default(cuid())
  name        String
  type        String
  channel     String
  status      String
  createdAt   DateTime          @default(now())
  flowConfig  Json?
  subject     String?
  body        String?
  scheduledAt DateTime?
  sentAt      DateTime?
  receipts    CampaignReceipt[]
  metrics     CampaignMetrics?
}

model CampaignReceipt {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel     String
  status      String
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  convertedAt DateTime?
  revenue     Float?

  @@index([campaignId, status])
  @@index([customerId])
}

model CampaignMetrics {
  id           String   @id @default(cuid())
  campaignId   String   @unique
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sent         Int      @default(0)
  delivered    Int      @default(0)
  opened       Int      @default(0)
  clicked      Int      @default(0)
  converted    Int      @default(0)
  revenue      Float    @default(0)
  unsubscribed Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model CampaignMemory {
  id                  String   @id @default(cuid())
  campaignId          String
  name                String
  campaignType        String?
  subjectLine         String?
  previewText         String?
  segment             String?
  sentAt              DateTime
  audienceSize        Int?
  openRate            Float?
  clickRate           Float?
  conversionRate      Float?
  orders              Int?
  revenue             Float    @default(0)
  revenuePerRecipient Float?
  notes               String?
  winningInsight      String?
  source              String   @default("manual")
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([campaignId])
  @@index([sentAt])
  @@index([segment, sentAt])
  @@index([campaignType, sentAt])
}

model CampaignPlan {
  id             String             @id @default(cuid())
  name           String
  dateRangeStart DateTime
  dateRangeEnd   DateTime
  status         String             @default("draft")
  summary        String?            @db.Text
  strategyNotes  String?            @db.Text
  metadata       Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  items          CampaignPlanItem[]

  @@index([status, createdAt])
  @@index([dateRangeStart, dateRangeEnd])
}

model CampaignPlanItem {
  id                String       @id @default(cuid())
  planId            String
  plan              CampaignPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  title             String
  campaignType      String
  goal              String
  segment           String
  suggestedSendDate DateTime
  subjectLineAngle  String?
  primaryProduct    String?
  why               String       @db.Text
  confidenceScore   Float?
  status            String       @default("proposed")
  metadata          Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  briefs            CampaignBrief[]

  @@index([planId, suggestedSendDate])
  @@index([campaignType])
  @@index([status])
}

model CampaignBrief {
  id             String                 @id @default(cuid())
  planItemId     String?
  planItem       CampaignPlanItem?      @relation(fields: [planItemId], references: [id], onDelete: SetNull)
  title          String
  campaignType   String
  segment        String
  goal           String
  subjectLines   Json
  previewTexts   Json
  angle          String                 @db.Text
  primaryProduct String?
  status         String                 @default("draft")
  designNotes    String?                @db.Text
  cta            String?
  metadata       Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  sections       CampaignBriefSection[]
  qaChecks       BriefQaCheck[]
  klaviyoDrafts  KlaviyoDraft[]

  @@index([planItemId])
  @@index([status, createdAt])
  @@index([campaignType])
  @@index([segment])
}

model CampaignBriefSection {
  id        String        @id @default(cuid())
  briefId   String
  brief     CampaignBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  type      String
  heading   String?
  body      String        @db.Text
  sortOrder Int           @default(0)
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([briefId, sortOrder])
  @@index([type])
}

model BriefQaCheck {
  id           String        @id @default(cuid())
  briefId      String
  brief        CampaignBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  status       String
  score        Int
  issues       Json
  warnings     Json
  passedChecks Json
  metadata     Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([briefId, createdAt])
  @@index([status, createdAt])
}

model KlaviyoDraft {
  id                 String        @id @default(cuid())
  briefId            String
  brief              CampaignBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  klaviyoCampaignId  String
  klaviyoTemplateId  String
  klaviyoMessageId   String?
  campaignName       String
  status             String        @default("draft_created")
  response           Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([briefId, createdAt])
  @@index([status, createdAt])
  @@index([klaviyoCampaignId])
  @@index([klaviyoTemplateId])
}

model WorkflowRun {
  id        String   @id @default(cuid())
  type      String
  status    String
  input     Json
  output    Json?
  error     String?  @db.Text
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

model Approval {
  id            String    @id @default(cuid())
  targetType    String
  targetId      String
  status        String    @default("pending")
  targetTitle   String?
  targetSummary String?   @db.Text
  requestNote   String?   @db.Text
  decisionNote  String?   @db.Text
  requestedBy   String?
  decidedBy     String?
  decidedAt     DateTime?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([targetType, targetId])
  @@index([status, createdAt])
  @@index([createdAt])
}

model ActionLog {
  id                  String   @id @default(cuid())
  eventType           String
  actionType          String
  status              String
  actorType           String   @default("system")
  targetType          String?
  targetId            String?
  workflowRunId       String?
  approvalId          String?
  riskLevel           String   @default("low")
  requiresApproval    Boolean  @default(false)
  approvalStatus      String?
  externalActionTaken Boolean  @default(false)
  canGoLiveNow        Boolean  @default(false)
  summary             String   @db.Text
  inputSummary        Json?
  outputSummary       Json?
  errorMessage        String?  @db.Text
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([eventType, createdAt])
  @@index([actionType, createdAt])
  @@index([status, createdAt])
  @@index([workflowRunId, createdAt])
  @@index([approvalId, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model RecommendationOutcome {
  id                  String    @id @default(cuid())
  sourceType          String
  sourceId            String
  sourceWorkflowRunId String?
  recommendationId    String?
  title               String
  summary             String?   @db.Text
  domain              String?
  actionType          String?
  targetType          String?
  targetId            String?
  status              String    @default("recommended")
  priority            String?
  confidence          Float?
  approvalId          String?
  actionLogId         String?
  decisionNote        String?   @db.Text
  outcomeNote         String?   @db.Text
  metadata            Json?
  decidedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([sourceWorkflowRunId, recommendationId])
  @@index([sourceType, sourceId])
  @@index([sourceType, sourceId, recommendationId])
  @@index([sourceWorkflowRunId, status])
  @@index([recommendationId])
  @@index([status, updatedAt])
  @@index([domain, status])
  @@index([actionType, status])
  @@index([targetType, targetId])
  @@index([approvalId])
  @@index([actionLogId])
  @@index([createdAt])
}

model RecommendationResult {
  id                      String    @id @default(cuid())
  sourceType              String
  sourceId                String
  recommendationOutcomeId String?
  workflowRunId           String?
  campaignMemoryId        String?
  externalPlatform        String?
  externalId              String?
  resultType              String
  status                  String    @default("received")
  timeframeStart          DateTime?
  timeframeEnd            DateTime?
  metrics                 Json?
  summary                 String?   @db.Text
  learningSignal          String
  learningStatus          String    @default("learned")
  lessons                 Json?
  metadata                Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([sourceType, sourceId])
  @@index([recommendationOutcomeId, createdAt])
  @@index([workflowRunId, createdAt])
  @@index([campaignMemoryId, createdAt])
  @@index([externalPlatform, externalId])
  @@index([resultType, status])
  @@index([learningSignal, createdAt])
  @@index([createdAt])
}

model WorklinSkill {
  id                       String    @id
  name                     String
  description              String    @db.Text
  category                 String
  status                   String    @default("draft")
  origin                   String    @default("agent_created")
  scope                    String    @default("workspace")
  runMode                  String    @default("assist")
  triggerExamples          Json?
  requiredInputs           Json?
  optionalInputs           Json?
  preferredSources         Json?
  fallbackSources          Json?
  requiredArtifacts        Json?
  optionalArtifacts        Json?
  missingSourceBehavior    Json?
  connectorDependencies    Json?
  requiredContext          Json?
  toolsUsed                Json?
  procedureSteps           Json?
  verificationChecklist    Json?
  pitfalls                 Json?
  safetyLevel              String    @default("low")
  approvalRequirements     Json?
  outputShape              Json?
  caveats                  Json?
  version                  String    @default("0.1.0")
  usageCount               Int       @default(0)
  lastUsedAt               DateTime?
  createdFromWorkflowRunId String?
  createdFromActionLogId   String?
  missingCapabilities      Json?
  workspaceContextSuggestions Json?
  oneOffDetailsNotSavedToSkill Json?
  metadata                 Json?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([status, category])
  @@index([runMode, status])
  @@index([origin, status])
  @@index([scope, status])
  @@index([createdFromWorkflowRunId])
  @@index([createdFromActionLogId])
  @@index([lastUsedAt])
  @@index([createdAt])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  name      String
  channel   String
  type      String
  subject   String?
  body      String
  createdAt DateTime @default(now())
}

model IntegrationState {
  id                       String   @id @default(cuid())
  provider                 String   @unique
  connected                Boolean  @default(false)
  accessToken              String?
  refreshToken             String?
  tokenExpiresAt           DateTime?
  lastSyncAt               DateTime?
  lastSyncStatus           String?
  lastSyncMessage          String?
  syncInProgress           Boolean  @default(false)
  shopifyLastOrdersSyncAt  DateTime?
  shopifyLastProductsSyncAt DateTime?
  shopifyLastCustomersSyncAt DateTime?
  shopifyLastRunId         String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model ShopifySyncRun {
  id                 String   @id @default(cuid())
  mode               String
  status             String
  triggeredBy        String?
  isBackground       Boolean  @default(false)
  startedAt          DateTime?
  completedAt        DateTime?
  sinceOrdersAt      DateTime?
  sinceProductsAt    DateTime?
  customersFetched   Int      @default(0)
  productsFetched    Int      @default(0)
  ordersFetched      Int      @default(0)
  customersUpserted  Int      @default(0)
  productsUpserted   Int      @default(0)
  ordersUpserted     Int      @default(0)
  warnings           Json?
  errorMessage       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status, createdAt])
}

model BrandProfile {
  id          String   @id @default(cuid())
  storeId     String   @unique @default("default")

  // Core Identity
  brandName        String?
  tagline          String?
  industry         String?
  niche            String?
  brandStory       String?
  usp              String?
  missionStatement String?
  websiteUrl       String?
  shopifyUrl       String?

  // Legacy compatibility fields
  industryVertical String?
  pricePositioning String?
  foundedYear      Int?
  coreValues       String[] @default([])
  shopifyStoreUrl  String?

  // Target Audience
  targetDemographics   String?
  targetPsychographics String?
  audiencePainPoints   String?
  audienceDesires      String?

  // Voice & Tone — 10 preset dimensions (0-100)
  voiceFormalCasual               Int @default(50)
  voiceSeriousPlayful             Int @default(50)
  voiceReservedEnthusiastic       Int @default(50)
  voiceTechnicalSimple            Int @default(50)
  voiceAuthoritativeApproachable  Int @default(50)
  voiceMinimalDescriptive         Int @default(50)
  voiceLuxuryAccessible           Int @default(50)
  voiceEdgySafe                   Int @default(50)
  voiceEmotionalRational          Int @default(50)
  voiceTrendyTimeless             Int @default(50)

  voiceDescription String?

  // Email Preferences
  greetingStyle       String? @default("friendly")
  signOffStyle        String? @default("warm")
  emojiUsage          String? @default("sparingly")
  preferredLength     String? @default("medium")
  discountPhilosophy  String? @default("strategically")

  // Analysis and related entities
  lastStoreAnalysis    DateTime?
  storeAnalysisData    Json?
  voiceTone            VoiceTone?
  dosAndDonts          DosAndDonts?
  productIntelligence  ProductIntelligence?
  compliance           Compliance?
  seasonalContext      SeasonalContext?
  personas             Persona[]
  sellingPoints        SellingPoint[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model CustomVoiceDimension {
  id          String   @id @default(cuid())
  storeId     String
  leftLabel   String
  rightLabel  String
  description String?
  value       Int      @default(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId, createdAt])
}

model BrandCTA {
  id          String   @id @default(cuid())
  storeId     String
  text        String
  isPreferred Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([storeId, createdAt])
}

model BrandPhrase {
  id          String   @id @default(cuid())
  storeId     String
  phrase      String
  type        String
  createdAt   DateTime @default(now())

  @@index([storeId, type, createdAt])
}

model BrandRule {
  id          String   @id @default(cuid())
  storeId     String
  rule        String
  type        String
  priority    String   @default("important")
  createdAt   DateTime @default(now())

  @@index([storeId, type, priority, createdAt])
}

model BrandProfileMeta {
  id      String @id @default(cuid())
  storeId String @unique
}

model Persona {
  id                String       @id @default(cuid())
  brandProfileId    String
  brandProfile      BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  name              String
  isPrimary         Boolean      @default(false)
  ageRange          String?
  genderSkew        String?
  locationPatterns  String[]
  incomeLevel       String?
  lifestyle         String[]
  values            String[]
  interests         String[]
  painPoints        String[]
  motivations       String[]
  objections        String[]
  languageTheyUse   String[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([brandProfileId, createdAt])
}

model SellingPoint {
  id              String       @id @default(cuid())
  brandProfileId  String
  brandProfile    BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  type            String
  title           String
  description     String?
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())

  @@index([brandProfileId, type, sortOrder])
}

model VoiceTone {
  id                    String       @id @default(cuid())
  brandProfileId        String       @unique
  brandProfile          BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  formalCasual          Int          @default(5)
  seriousPlayful        Int          @default(5)
  reservedEnthusiastic  Int          @default(5)
  technicalSimple       Int          @default(5)
  traditionalEdgy       Int          @default(5)
  corporatePersonal     Int          @default(5)
  welcomeTone           Json?
  promotionalTone       Json?
  educationalTone       Json?
  vipTone               Json?
  winbackTone           Json?
  transactionalTone     Json?
  apologyTone           Json?
  launchTone            Json?
  sentenceLength        String?
  paragraphLength       String?
  useContractions       String?
  useExclamations       String?
  emojiUsage            Json?
  useCaps               String?
  preferredAdjectives   String[]
  preferredVerbs        String[]
  preferredCTAs         String[]
  signaturePhrases      String[]
  greetingStyle         String?
  signoffStyle          String?
  customerReference     String?
  brandReference        String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model DosAndDonts {
  id                String       @id @default(cuid())
  brandProfileId    String       @unique
  brandProfile      BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  messagingDos      Json?
  languageDos       Json?
  complianceDos     Json?
  designDos         Json?
  timingDos         Json?
  messagingDonts    Json?
  languageDonts     Json?
  complianceDonts   Json?
  designDonts       Json?
  toneDonts         Json?
  cautionRules      Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model ProductIntelligence {
  id                 String       @id @default(cuid())
  brandProfileId     String       @unique
  brandProfile       BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  descriptionStyle   String?
  priceMentionRule   String?
  products           Json?
  collections        Json?
  heroProducts       String[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Compliance {
  id                     String       @id @default(cuid())
  brandProfileId         String       @unique
  brandProfile           BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  physicalAddress        String?
  unsubscribeText        String?
  smsOptOutText          String?
  privacyPolicyUrl       String?
  termsUrl               String?
  fdaDisclaimer          String?
  prop65Warning          String?
  subscriptionDisclosure String?
  autoRenewalLanguage    String?
  customDisclaimers      String[]
  trademarkRules         String?
  ugcRightsText          String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model SeasonalContext {
  id                  String       @id @default(cuid())
  brandProfileId      String       @unique
  brandProfile        BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  celebratedHolidays  String[]
  skippedHolidays     String[]
  brandAnniversary    DateTime?
  plannedSales        Json?
  blackoutDates       DateTime[]
  blackoutTopics      Json?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model BrandDocument {
  id              String   @id @default(cuid())
  storeId         String   @default("default")
  fileName        String
  fileType        String // "pdf", "docx", "txt"
  fileSize        Int // bytes
  fileUrl         String? // Vercel Blob URL or data URL fallback
  rawText         String   @db.Text
  summary         String?  @db.Text
  extractedRules  String?  @db.Text // JSON string of brandInsights from LLM
  status          String   @default("uploaded") // uploaded, processing, completed, failed
  appliedToProfile Boolean @default(false)
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId, createdAt])
}

model StoreScreenshot {
  id                String   @id @default(cuid())
  brandProfileId    String
  pageType          String
  pageUrl           String
  screenshotUrl     String
  extractedElements Json?
  capturedAt        DateTime @default(now())

  @@index([brandProfileId, capturedAt])
}

model ChatSession {
  id        String        @id @default(cuid())
  storeId   String        @default("default")
  title     String?       @default("New Chat")
  status    String        @default("active")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([storeId, updatedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // user, assistant, system, tool
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([sessionId, createdAt])
}

model Competitor {
  id                  String           @id @default(cuid())
  storeId             String           @default("default")
  name                String
  url                 String
  industry            String?
  niche               String?
  analysis            String?          @db.Text
  strengths           String?        @db.Text
  weaknesses          String?        @db.Text
  whatTheyDoBetter    String?        @db.Text
  messagingStrategy   String?        @db.Text
  pricingStrategy     String?        @db.Text
  emailStrategy       String?        @db.Text
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  competitorEmails    CompetitorEmail[]

  @@unique([storeId, url])
  @@index([storeId, updatedAt])
}

model CompetitorEmail {
  id              String      @id @default(cuid())
  storeId         String      @default("default")
  competitorId    String?
  competitor      Competitor? @relation(fields: [competitorId], references: [id], onDelete: SetNull)
  competitorName  String?
  emailContent    String      @db.Text
  analysis        String?     @db.Text
  subjectLine     String?
  emailType       String?
  createdAt       DateTime    @default(now())

  @@index([storeId, createdAt])
  @@index([competitorId])
}
