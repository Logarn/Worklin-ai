{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "runtime/Dockerfile",
    "watchPatterns": [
      ".dockerignore",
      "assistant/**",
      "control-plane/**",
      "credential-executor/**",
      "gateway/**",
      "packages/**",
      "railway.json",
      "runtime/**",
      "skills/**"
    ]
  },
  "deploy": {
    "startCommand": "env VELLUM_FLAG_SETTINGS_DEVELOPER_NAV=true VELLUM_FLAG_VOICE_MODE=true /app/runtime/entrypoint.sh",
    "healthcheckPath": "/readyz",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
